/* ── STATE TRANSITIONS ── */

function setCol2(ci,mode,html){
  const el=document.getElementById('col2');
  el.innerHTML=html;
  el.classList.add('open');
  col2Mode=mode;
  /* merge border with col3 when col3 is open */
  el.classList.toggle('merged',activeJob>=0);
  const dh=parseInt(document.getElementById('deck-root').style.height)||220;
  el.style.minHeight=dh+'px';
}

function setCol3(html){
  const el=document.getElementById('col3');
  if(html===null){el.classList.remove('open');el.innerHTML='';activeJob=-1;}
  else{el.innerHTML=html;el.classList.add('open');}
  /* update col2 border */
  document.getElementById('col2').classList.toggle('merged',html!==null);
}

function openCard(ci,e){
  if(e) e.stopPropagation();
  activeJob=-1;
  setCol3(null);
  setCol2(ci,'card',renderCard(ci));
}

function openFullSheet(ci,e){
  if(e) e.stopPropagation();
  activeJob=-1;
  setCol3(null);
  setCol2(ci,'full',renderFullSheet(ci));
}

function selectJob(ci,ji,e){
  if(e) e.stopPropagation();
  /* toggle off */
  if(activeJob===ji&&activeCand===ci){closeJob(e);return;}
  activeJob=ji;
  /* re-render col2 so spine gets active-exp class */
  setCol2(ci,'full',renderFullSheet(ci));
  setCol3(renderJob(ci,ji));
}

function closeJob(e){
  if(e) e.stopPropagation();
  activeJob=-1;
  setCol3(null);
  /* re-render col2 to clear active-exp */
  setCol2(activeCand,'full',renderFullSheet(activeCand));
}

/* ── CANDIDATE DECK ── */
function reflowDeck(ai){
  const root=document.getElementById('deck-root');
  const H=(N-1)*SPINE_GAP+SPINE_H;
  root.style.height=H+'px';
  data.forEach((_,i)=>{
    spineEls[i].style.top=(i*SPINE_GAP)+'px';
    spineEls[i].style.zIndex=N-i;
    spineEls[i].classList.toggle('active',i===ai);
  });
  if(ai<0){
    document.getElementById('col2').classList.remove('open');
    setCol3(null);
  } else {
    document.getElementById('col2').style.minHeight=H+'px';
  }
}

function toggleCand(idx){
  if(activeCand===idx){
    activeCand=-1;activeJob=-1;
    reflowDeck(-1);
    document.getElementById('col2').classList.remove('open');
    setCol3(null);
    return;
  }
  activeCand=idx;activeJob=-1;
  reflowDeck(idx);
  openCard(idx,null);
}

const root=document.getElementById('deck-root');
data.forEach((c,i)=>{
  const el=document.createElement('div');
  el.className='spine';el.id='spine-'+i;
  el.style.top=(i*SPINE_GAP)+'px';el.style.zIndex=N-i;
  el.onclick=()=>toggleCand(i);
  el.innerHTML=`
    <div class="av-xs" style="background:${c.bg};color:${c.col}">${c.initials}</div>
    <div class="name-block">
      <span class="spine-name">${c.name}</span>
      ${badge(c.roleType,c.roleLabel,c.grade)}
    </div>
    <div class="tech-strip">${c.spineIcons.map(([k,l])=>icoSpine(k,l)).join('')}</div>`;
  root.appendChild(el);spineEls.push(el);
});

reflowDeck(-1);
