
<style>
*{box-sizing:border-box;margin:0;padding:0;}
.stage{padding:1.5rem 0.5rem 3rem;display:flex;flex-direction:column;align-items:flex-start;font-family:var(--font-sans,sans-serif);}
.hint{font-size:12px;color:var(--color-text-secondary);margin-bottom:14px;padding-left:2px;}

/* ══ THREE-COLUMN TABLET ══ */
.tablet{display:flex;align-items:flex-start;gap:0;width:100%;}

/* col 1 — candidate deck */
.col1{flex-shrink:0;width:238px;}
.deck-root{position:relative;width:238px;}

/* col 2 — candidate detail / full sheet */
.col2{
  flex-shrink:0;width:0;overflow:hidden;
  border:0.5px solid var(--color-border-secondary);border-left:none;
  border-radius:0 10px 10px 0;
  background:var(--color-background-primary);
  transition:width 0s;
  display:none;
  align-self:stretch;
}
.col2.open{display:block;width:220px;}
/* when col3 is also open, col2 loses its right radius */
.col2.merged{border-radius:0;border-right:none;}

/* col 3 — job detail */
.col3{
  flex:1;min-width:0;
  border:0.5px solid var(--color-border-secondary);border-left:none;
  border-radius:0 10px 10px 0;
  background:var(--color-background-primary);
  display:none;
  align-self:stretch;
}
.col3.open{display:block;}

/* ══ CANDIDATE SPINES ══ */
.spine{
  position:absolute;left:0;width:238px;height:52px;
  border-radius:10px;border:0.5px solid var(--color-border-secondary);
  background:var(--color-background-primary);cursor:pointer;
  display:flex;align-items:center;padding:0 8px;gap:6px;
  transition:top 0.3s cubic-bezier(.4,0,.2,1);will-change:top;
}
.spine:not(.active):hover{background:var(--color-background-secondary);}
.spine.active{border-radius:10px 0 0 10px;border-right:none;cursor:default;z-index:50!important;}

/* ══ EXP SPINES (inside col2 full sheet) ══ */
.exp-spine{
  position:absolute;left:0;height:44px;
  border-radius:8px;border:0.5px solid var(--color-border-secondary);
  background:var(--color-background-primary);cursor:pointer;
  display:flex;align-items:center;padding:0 7px;gap:5px;
  transition:top .28s cubic-bezier(.4,0,.2,1);will-change:top;
}
.exp-spine:not(.active-exp):hover{background:var(--color-background-secondary);}
/* active exp spine merges with col3 on the right */
.exp-spine.active-exp{border-radius:8px 0 0 8px;border-right:none;cursor:default;z-index:20!important;}

/* ══ SHARED TOKENS ══ */
.av-xs{width:26px;height:26px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:500;flex-shrink:0;}
.av-sm{width:30px;height:30px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:500;flex-shrink:0;}
.co-logo{width:22px;height:22px;border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:500;flex-shrink:0;}
.name-block{flex:1;min-width:0;display:flex;align-items:center;gap:4px;overflow:hidden;}
.spine-name{font-size:12px;font-weight:500;color:var(--color-text-primary);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.exp-name-block{flex:1;min-width:0;display:flex;align-items:center;gap:3px;overflow:hidden;}
.exp-job-title{font-size:11px;font-weight:500;color:var(--color-text-primary);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.exp-period{font-size:10px;color:var(--color-text-secondary);flex-shrink:0;white-space:nowrap;}

.badge{display:inline-flex;align-items:center;gap:0;flex-shrink:0;position:relative;cursor:default;}
.badge-role{color:var(--color-text-secondary);display:flex;align-items:center;width:15px;height:15px;flex-shrink:0;}
.badge-role svg{width:13px;height:13px;display:block;}
.chev-col{width:13px;display:flex;flex-direction:column;align-items:center;gap:2px;flex-shrink:0;}
.badge:hover .tooltip{opacity:1;transform:translateX(-50%) translateY(0);}

.tooltip{position:absolute;bottom:calc(100% + 5px);left:50%;transform:translateX(-50%) translateY(4px);background:var(--color-background-primary);border:0.5px solid var(--color-border-secondary);border-radius:6px;padding:3px 7px;font-size:11px;color:var(--color-text-primary);white-space:nowrap;opacity:0;transition:opacity .15s,transform .15s;pointer-events:none;z-index:400;}
.ti:hover .tooltip,.ico:hover .tooltip,.exp-ico:hover .tooltip,.contact-ico:hover .tooltip{opacity:1;transform:translateX(-50%) translateY(0);}

.tech-strip{display:flex;gap:2px;flex-shrink:0;}
.ti{position:relative;width:19px;height:19px;border-radius:4px;background:var(--color-background-secondary);display:flex;align-items:center;justify-content:center;flex-shrink:0;overflow:visible;cursor:default;}
.ti svg{width:11px;height:11px;display:block;}

.sec{padding:7px 10px;border-top:0.5px solid var(--color-border-tertiary);}
.sec:first-child{border-top:none;}
.sec-title{font-size:10px;font-weight:500;color:var(--color-text-secondary);letter-spacing:.06em;text-transform:uppercase;margin-bottom:4px;}
.stat-row{display:flex;gap:4px;padding:7px 10px 5px;}
.stat-b{flex:1;background:var(--color-background-secondary);border-radius:6px;padding:4px 2px;text-align:center;}
.stat-v{font-size:13px;font-weight:500;color:var(--color-text-primary);line-height:1;}
.stat-l{font-size:10px;color:var(--color-text-secondary);margin-top:2px;}
.stack-row{display:flex;flex-wrap:wrap;gap:3px;margin-top:3px;}
.ico{position:relative;width:22px;height:22px;border-radius:5px;background:var(--color-background-secondary);border:0.5px solid var(--color-border-tertiary);display:flex;align-items:center;justify-content:center;cursor:default;overflow:visible;}
.ico.core{background:var(--color-background-info);border-color:var(--color-border-info);}
.ico.dim{opacity:.38;}
.ico svg{width:13px;height:13px;display:block;}
.exp-ico{position:relative;width:19px;height:19px;border-radius:4px;background:var(--color-background-secondary);border:0.5px solid var(--color-border-tertiary);display:flex;align-items:center;justify-content:center;cursor:default;overflow:visible;}
.exp-ico.core{background:var(--color-background-info);border-color:var(--color-border-info);}
.exp-ico svg{width:11px;height:11px;display:block;}
.demo-grid{display:grid;grid-template-columns:1fr 1fr;gap:3px 8px;margin-top:2px;}
.demo-item{display:flex;align-items:baseline;gap:3px;}
.demo-lbl{font-size:10px;color:var(--color-text-secondary);flex-shrink:0;}
.demo-val{font-size:11px;color:var(--color-text-primary);}
.action-row{padding:5px 10px 6px;border-top:0.5px solid var(--color-border-tertiary);display:flex;gap:4px;}
.act-btn{font-size:11px;padding:3px 7px;border-radius:6px;cursor:pointer;border:0.5px solid var(--color-border-secondary);background:transparent;color:var(--color-text-secondary);}
.act-btn:hover{background:var(--color-background-secondary);}
.act-btn.primary{color:var(--color-text-info);border-color:var(--color-border-info);}
.contacts-bar{display:flex;align-items:center;gap:4px;padding:5px 10px;border-top:0.5px solid var(--color-border-tertiary);background:var(--color-background-secondary);}
.contact-ico{position:relative;width:20px;height:20px;border-radius:4px;background:var(--color-background-primary);border:0.5px solid var(--color-border-tertiary);display:flex;align-items:center;justify-content:center;cursor:default;flex-shrink:0;overflow:visible;color:var(--color-text-secondary);}
.contact-ico svg{width:11px;height:11px;display:block;}
.fs-header{padding:9px 10px;display:flex;gap:8px;align-items:center;border-bottom:0.5px solid var(--color-border-tertiary);}
.fs-name{font-size:13px;font-weight:500;color:var(--color-text-primary);}
.fs-role{font-size:10px;color:var(--color-text-secondary);margin-top:1px;}
.fs-match{text-align:center;background:var(--color-background-secondary);border-radius:6px;padding:3px 7px;flex-shrink:0;}
.fs-match-v{font-size:14px;font-weight:500;color:var(--color-text-primary);line-height:1;}
.fs-match-l{font-size:10px;color:var(--color-text-secondary);}
.proj{padding:5px 7px;border-radius:6px;border:0.5px solid var(--color-border-tertiary);margin-bottom:4px;}
.proj-title{font-size:11px;font-weight:500;color:var(--color-text-primary);}
.proj-meta{font-size:10px;color:var(--color-text-secondary);margin-top:1px;}
.proj-tags{display:flex;flex-wrap:wrap;gap:2px;margin-top:3px;}
.proj-tag{padding:1px 4px;border-radius:3px;font-size:10px;background:var(--color-background-secondary);color:var(--color-text-secondary);}
.proj-tag.hl{background:var(--color-background-success);color:var(--color-text-success);}
.back-row{padding:5px 10px 6px;border-top:0.5px solid var(--color-border-tertiary);display:flex;gap:4px;}
.back-btn{font-size:11px;padding:3px 7px;border-radius:6px;cursor:pointer;border:0.5px solid var(--color-border-secondary);background:transparent;color:var(--color-text-secondary);}
.back-btn:hover{background:var(--color-background-secondary);}
.exp-ach{display:flex;gap:4px;align-items:flex-start;margin-bottom:3px;}
.exp-ach-dot{width:3px;height:3px;border-radius:50%;background:var(--color-text-secondary);flex-shrink:0;margin-top:4px;}
.exp-ach-txt{font-size:11px;color:var(--color-text-primary);line-height:1.4;flex:1;}
.exp-ach-tag{display:inline-block;padding:1px 4px;border-radius:3px;font-size:10px;background:var(--color-background-success);color:var(--color-text-success);margin-left:3px;}
.exp-stack-row{display:flex;flex-wrap:wrap;gap:2px;margin-top:3px;}
.job-header{padding:8px 10px;display:flex;gap:7px;align-items:center;border-bottom:0.5px solid var(--color-border-tertiary);}
.job-company-name{font-size:12px;font-weight:500;color:var(--color-text-primary);}
.job-period{font-size:10px;color:var(--color-text-secondary);}
</style>

<div class="stage">
<div class="hint">Корешок → карточка → «Полный лист» → место работы открывается в колонке 3</div>
<div class="tablet" id="tablet">
  <div class="col1"><div id="deck-root" class="deck-root"></div></div>
  <div class="col2" id="col2"></div>
  <div class="col3" id="col3"></div>
</div>
</div>

<script>
const IC={
