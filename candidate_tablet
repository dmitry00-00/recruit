};
const GRADES={Junior:{n:1,col:'#888780'},Middle:{n:2,col:'#1D9E75'},Senior:{n:3,col:'#185FA5'},Lead:{n:4,col:'#854F0B'}};
const SPINE_H=52,SPINE_GAP=52,EXP_H=44,EXP_GAP=44;

function tip(l){return `<span class="tooltip">${l}</span>`;}
function icoStack(k,l,cls=''){return `<span class="ico${cls?' '+cls:''}">${IC[k]||''}${tip(l)}</span>`;}
function icoE(k,l,cls=''){return `<span class="exp-ico${cls?' '+cls:''}">${IC[k]||''}${tip(l)}</span>`;}
function icoSpine(k,l){return `<span class="ti">${IC[k]||''}${tip(l)}</span>`;}

function makeChevrons(grade){
  const g=GRADES[grade]||GRADES.Middle;
  const W=12,H=5,GAP=2.5,svgH=g.n*H+(g.n-1)*GAP+1;
  let p='';
  for(let i=0;i<g.n;i++){const y=0.5+i*(H+GAP);p+=`<path d="M1 ${y} L${W/2} ${y+H-0.5} L${W-1} ${y}" stroke="${g.col}" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/>`;}
  return `<svg width="${W}" height="${svgH}" viewBox="0 0 ${W} ${svgH}" style="display:block;">${p}</svg>`;
}
function badge(rt,rl,grade){
  return `<span class="badge" title="${rl} · ${grade}"><span class="badge-role">${ROLES[rt]||ROLES.frontend}</span><span class="chev-col">${makeChevrons(grade)}</span><span class="tooltip">${rl} · ${grade}</span></span>`;
}
function cbar(ct){
  const a=[];
  if(ct.phone) a.push(`<span class="contact-ico">${CONT_IC.phone}${tip(ct.phone)}</span>`);
  if(ct.email) a.push(`<span class="contact-ico">${CONT_IC.email}${tip(ct.email)}</span>`);
